            <!-- Waline 评论区 ✅ 保留 -->
            <% if (theme.waline && theme.waline.enable) { %>
            <div class="card" data-aos="fade-up">
                <div class="comment_headling" style="font-size: 20px; font-weight: 700; position: relative; padding-left: 20px; top: 15px; padding-bottom: 5px;">
                    <i class="fas fa-comments fa-fw" aria-hidden="true"></i>
                    <span>Waline 评论</span>
                </div>
                <div class="card-content">
                    <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
                    <div id="waline-contact"></div>
                    <script type="module">
                        import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
                        init({
                            el: '#waline-contact',
                            serverURL: '<%- theme.waline.serverURL %>',
                            lang: 'zh-CN',
                            pageview: true,
                            comment: true,
                            imageUploader: async (file) => {
                                const CLOUD = '<%- (theme.waline.cloudinary && theme.waline.cloudinary.cloudName) || "" %>';
                                const PRESET = '<%- (theme.waline.cloudinary && theme.waline.cloudinary.uploadPreset) || "" %>';
                                if (!CLOUD || !PRESET) {
                                    throw new Error('未配置 Cloudinary，请在 _config.yml 的 waline.cloudinary 里设置 cloudName 和 uploadPreset');
                                }
                                const formData = new FormData();
                                formData.append('file', file);
                                formData.append('upload_preset', PRESET);
                                const resp = await fetch('https://api.cloudinary.com/v1_1/' + CLOUD + '/image/upload', {
                                    method: 'POST',
                                    body: formData,
                                });
                                if (!resp.ok) throw new Error('Upload failed: ' + resp.status);
                                const data = await resp.json();
                                if (!data.secure_url) throw new Error('Upload failed: ' + (data.error && data.error.message || 'unknown'));
                                return data.secure_url;
                            },
                        });
                    </script>
                </div>
            </div>
            <% } %>

            <!-- 已关闭: Giscus -->
            <!--
            <div class="card" data-aos="fade-up">
                <div class="comment_headling" style="font-size: 20px; font-weight: 700; position: relative; padding-left: 20px; top: 15px; padding-bottom: 5px;">
