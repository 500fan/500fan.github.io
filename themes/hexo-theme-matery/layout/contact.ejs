                <div class="tag-title center-align">
                    <i class="fas fa-comments"></i>&nbsp;&nbsp;<%= __('contact') %>
                </div>
                <%- page.content %>
            </div>
            <!--valine评论弹幕-->
            <% if (theme.twikoo && theme.twikoo.enable) { %>
                <p style="color: #00ff00; opacity: 1.0; text-shadow: 0 0 10px rgba(0,255,0,0.3);">
                    <b>讨论互动</b><br>
                    <b>···</b><br>
                    <b>友链信息</b><br>
                    <b>博客名称: <%- config.title %></b><br>
                    <b>博客网址: <%- config.url %></b><br>
                    <b>博客头像: <%- config.url %>/medias/logo.png</b><br>
                    <b>博客介绍: 犹豫就会败北</b><br>
                    <b>···</b>
                    <b></b>
                </p>
                <div class="container barrage-container">
                    <section id="custom" class="bb-section">
                        <div class="row">
                            <div class="col-md-5">
                                <form class="form-inline">
                                    <div class="form-group">
                                        文字：<input class="form-control" name="info" type="text" placeholder="这里输入展示的样式为弹幕,留言内容会同步在弹屏"/>
                                    </div>
                                    <div class="form-group">
                                        链接：<input class="form-control" name="href" type="text" placeholder="https://mp.weixin.qq.com/s?__biz=MzUzOTEyOTI1MQ==&mid=2247488419&idx=1&sn=a849b45711b5b96f8ca91296242cd7ad&chksm=facc776fcdbbfe79b8e7dcddf272a7582064c62a9e854c69261d9dfb3b9bf75338e68603d30b&token=63507328&lang=zh_CN#rd"/>
                                    </div>
                                    <div class="form-group">
                                        速度：<input  class="form-control"  name="speed" type="text" placeholder="number输入5~20弹屏速度，数字越大弹屏速度越慢" value="16" />
                                    </div>
                                </form>
                                <div class="form-group">
                                    <button id="send"  class="btn" onclick="run()">留言</button>
                                    <button id="clear" class="btn " onclick="clear_barrage()"> 清除</button>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <div id="barrage-twikoo" style="display:none;"></div>
                <!-- 不加载 Twikoo SDK，直接 HTTP 请求 Render 服务器 -->
                <script type="text/javascript">
                    var TWIKOO_SERVER = '<%- theme.twikoo.envId %>';
                    var barrageQueue = [];
                    var barrageLoopTimer = null;

                    // 页面加载后直接获取弹幕
                    jQuery(function() {
                        loadBarrages();
                    });

                    // POST 请求到 Twikoo 服务器
                    function twikooPost(data) {
                        return fetch(TWIKOO_SERVER, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        }).then(function(r) { return r.json(); });
                    }

                    // 解析弹幕内容
                    function parseBarrageItem(item) {
                        try {
                            var match = item.comment.match(/\[barrage\](.*?)\[\/barrage\]/);
                            if (match) {
                                var parts = match[1].split('|');
                                return {
                                    img: '/medias/barrager/' + Math.floor(Math.random() * 3) + '.png',
                                    href: parts[1] || 'javascript:;',
                                    info: parts[0] || '',
                                    speed: parseInt(parts[2]) || 16
                                };
                            }
                        } catch (e) {}
                        return null;
                    }

                    // 加载历史弹幕
                    function loadBarrages() {
                        twikooPost({
                            event: 'GET_RECENT_COMMENTS',
                            urls: ['/barrage'],
                            pageSize: 100,
                            includeReply: true
                        }).then(function(resp) {
                            var lists = resp.data || [];
                            barrageQueue = [];
                            for (var i = 0; i < lists.length; i++) {
                                var b = parseBarrageItem(lists[i]);
                                if (b) barrageQueue.push(b);
                            }
                            console.log('弹幕加载成功:', barrageQueue.length, '条');
                            if (barrageQueue.length > 0) startBarrageLoop();
                        }).catch(function(e) {
                            console.error('弹幕加载失败:', e);
                        });
                    }

                    // 循环飞入弹幕
                    function startBarrageLoop() {
                        if (barrageLoopTimer) clearTimeout(barrageLoopTimer);
                        function next() {
                            if (barrageQueue.length === 0) {
                                barrageLoopTimer = setTimeout(next, 3000);
                                return;
                            }
                            jQuery('body').barrager(barrageQueue[Math.floor(Math.random() * barrageQueue.length)]);
                            barrageLoopTimer = setTimeout(next, Math.floor(Math.random() * 2000) + 1000);
                        }
                        next();
                    }

                    // 发送弹幕
                    function run() {
                        var info = jQuery('input[name=info]').val();
                        if (info === '') info = 'hello world';
                        var href = jQuery('input[name=href]').val();
                        if (href === '') href = 'https://fuliefu-e0f643.gitlab.io/artitalk/';
                        var speed = parseInt(jQuery('input[name=speed]').val());
                        if (speed > 20 || speed < 5) speed = Math.floor(Math.random() * 10) + 5;

                        var barrageContent = '[barrage]' + info + '|' + href + '|' + speed + '[/barrage]';

                        twikooPost({
                            event: 'COMMENT_SUBMIT',
                            nick: '弹幕', mail: 'barrage@example.com', link: href,
                            comment: barrageContent, url: '/barrage',
                            pid: '', rid: '',
                            ua: navigator.userAgent
                        }).then(function(resp) {
                            if (resp && resp.id) {
                                var b = { img: '/medias/barrager/' + Math.floor(Math.random() * 3) + '.png', href: href, info: info, speed: speed };
                                jQuery('body').barrager(b);
                                barrageQueue.push(b);
                                jQuery("input[name='info']").val('');
                                jQuery("input[name='href']").val('');
                                jQuery("input[name='speed']").val('');
                            } else {
                                alert('留言发送失败：' + (resp && resp.message || '未知错误'));
                            }
                        }).catch(function(e) {
                            alert('留言发送失败，请检查网络');
                            console.error('弹幕发送失败:', e);
                        });
                    }

                    function clear_barrage() {
                        jQuery.fn.barrager.removeAll();
                        if (barrageLoopTimer) { clearTimeout(barrageLoopTimer); barrageLoopTimer = null; }
                    }
                </script>
            <% } %>
        </div>



   
          

          
