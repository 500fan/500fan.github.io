<div class="dream">
    <% if (theme.dream.showTitle) { %>
    <div class="title center-align">
        <div class="label" style="color: rgb(74, 248, 21);">
            <!-- dream介绍-->
            <img class="labelmz" src="/medias/spring-img/2.png">
            <img class="labelmzsd" src="/medias/christmas-img/9.png">
            <span>日渐富有</span></div>
        <i class="fas fa-clock fa-fw"></i>&nbsp;&nbsp;<%= theme.dream.title %>
    </div>
    <% } %>
    <div class="row">
        <div class="col l8 offset-l2 m10 offset-m1 s10 offset-s1 center-align text">
            <%= theme.dream.text %>
        </div>
    </div>
</div>