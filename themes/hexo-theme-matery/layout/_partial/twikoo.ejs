<link rel="stylesheet" href="/css/twikoo-custom.css">

<div class="twikoo-cyber-container">
    <div class="cyber-decoration cyber-decoration-1"></div>
    <div class="cyber-decoration cyber-decoration-2"></div>

    <div class="twikoo-cyber-card">
        <div class="twikoo-cyber-header">
            <div class="twikoo-cyber-title">
                <i class="fas fa-comments"></i>
                <span>留言互动</span>
            </div>
            <div style="font-size: 0.8rem; color: #6b7280;">
                Powered by Twikoo
            </div>
        </div>

        <div class="twikoo-comments-wrapper">
            <div id="tcomments"></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/twikoo@1.7.13/dist/twikoo.all.min.js"></script>
<script>
    if (typeof twikoo !== 'undefined') {
        twikoo.init({
            envId: '<%- theme.twikoo.envId %>',
            el: '#tcomments',
            region: '',
            path: window.location.pathname,
            placeholder: '留下你的想法...'
        }).then(function() {
            console.log('[Twikoo] 初始化成功');
        }).catch(function(e) {
            console.error('[Twikoo] 初始化失败:', e);
        });
    } else {
        console.error('[Twikoo] 脚本未加载');
    }
</script>
