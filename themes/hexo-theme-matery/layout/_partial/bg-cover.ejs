<div class="bg-cover pd-header about-cover" style="position: relative; overflow: hidden;">
    <div class="container">
    <%- partial('_partial/bg-cover-content') %>
    </div>
    <style>
    .about-cover .bubbles-bg > .particle {
        opacity: 0;
        position: absolute;
        background-color: rgba(128,255,0,0.7);
        animation: bubblesBg 60s ease-in infinite;
        border-radius: 100%;
    }
    @keyframes bubblesBg {
        0% { opacity: 0; }
        5% { opacity: 1; transform: translate(0, -20%); }
        100% { opacity: 0; transform: translate(0, -80000%); }
    }
    </style>
    <div style="width: 100%; height: 100%; position: absolute; bottom: 0; left: 0;" class="particletext bubbles-bg"></div>
    <script type="text/javascript" src="https://code.jquery.com/jquery-3.1.1.min.js"></script>
    <script>
      $(function(){
        if(!jQuery.rnd) {
          jQuery.rnd = function(m,n) {
            m = parseInt(m);
            n = parseInt(n);
            return Math.floor(Math.random() * (n - m + 1)) + m;
          }
        }
        $.each($(".particletext.bubbles-bg"), function(){
          var bubblecount = ($(this).width()/50)*10;
          for(var i = 0; i <= bubblecount; i++) {
            var size = ($.rnd(40,80)/10);
            $(this).append('<span class="particle" style="top:' + $.rnd(20,80) + '%; left:' + $.rnd(0,95) + '%;width:' + size + 'px; height:' + size + 'px;animation-delay: ' + ($.rnd(0,180)/10) + 's;"></span>');
          }
        });
      });
    </script>
</div>
