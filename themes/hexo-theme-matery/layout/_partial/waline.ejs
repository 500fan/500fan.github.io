<link rel="stylesheet" href="/css/waline-custom.css">
<link rel="stylesheet" href="https://unpkg.com/@waline/client@v2/dist/waline.css" />

<div class="waline-container">
    <div class="waline-card">
        <!-- 头部 -->
        <div class="waline-header">
            <div class="waline-title">
                <i class="fas fa-comments"></i>
                <span>评论互动</span>
            </div>
            <div class="waline-stats" id="waline-stats">
                <span class="waline-stat-item">
                    <span class="waline-stat-number" id="waline-count">-</span>
                    <span class="waline-stat-label">条评论</span>
                </span>
            </div>
        </div>

        <!-- 评论区 -->
        <div class="waline-content">
            <div id="waline"></div>
        </div>
    </div>
</div>

<script type="module">
    import { init } from 'https://unpkg.com/@waline/client@v2/dist/waline.js';

    const serverURL = '<%- theme.waline.serverURL %>';
    const cloudinaryCloudName = '<%- (theme.waline.cloudinary && theme.waline.cloudinary.cloudName) || "" %>';
    const cloudinaryUploadPreset = '<%- (theme.waline.cloudinary && theme.waline.cloudinary.uploadPreset) || "" %>';

    // 图片上传
    async function imageUploader(file) {
        if (cloudinaryCloudName && cloudinaryUploadPreset) {
            const formData = new FormData();
            formData.append('file', file);
            formData.append('upload_preset', cloudinaryUploadPreset);

            const resp = await fetch(
                `https://api.cloudinary.com/v1_1/${cloudinaryCloudName}/image/upload`,
                { method: 'POST', body: formData }
            );
            const result = await resp.json();
            if (result.secure_url) return result.secure_url;
            throw new Error((result.error && result.error.message) || 'Cloudinary upload failed');
        }

        const formData = new FormData();
        formData.append('file', file);
        const resp = await fetch(serverURL + '/api/upload', {
            method: 'POST',
            body: formData,
        });
        const result = await resp.json();
        if (result.errno === 0) return result.data;
        throw new Error(result.errmsg || 'Upload failed');
    }

    // 初始化 Waline
    const walineInstance = init({
        el: '#waline',
        serverURL: serverURL,
        lang: '<% if (config.language == "zh-CN") { %>zh-CN<% } else { %>en<% } %>',
        pageview: true,
        comment: true,
        imageUploader: imageUploader,
        reaction: true,
        meta: ['nick', 'mail', 'link'],
        requiredMeta: ['nick'],
        emoji: [
            'https://unpkg.com/@waline/emojis@1.2.0/weibo',
            'https://unpkg.com/@waline/emojis@1.2.0/bilibili',
        ],
        comment: true,
    });

    // 加载评论统计
    async function loadStats() {
        try {
            const resp = await fetch(serverURL + '/api/comment?path=' + encodeURIComponent(window.location.pathname) + '&pageSize=1');
            const data = await resp.json();
            if (data.data && data.data.count !== undefined) {
                document.getElementById('waline-count').textContent = data.data.count;
            }
        } catch (e) {
            console.error('[Waline] 加载统计失败:', e);
        }
    }

    // 页面加载后获取统计
    setTimeout(loadStats, 2000);
</script>
